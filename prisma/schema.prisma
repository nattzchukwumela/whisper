// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        Int      @id @unique @default(autoincrement())
  name      String
  email     String   @unique
  password  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // link that others use to send anonymous messages
  uniqueLink String @unique

  // messages received by this user
  messages     AnonymousMessage[]
  RefreshToken RefreshToken[]
}

model AnonymousMessage {
  id        Int      @id @default(autoincrement())
  text      String
  category  Category
  createdAt DateTime @default(now())

  // reference to the receiver (the User who owns the unique link)
  receiverId Int
  receiver   User @relation(fields: [receiverId], references: [id])
}

model RefreshToken {
  id        Int    @id @default(autoincrement())
  tokenHash String @unique // store a SHA-256 hash of the refresh token
  userId    Int
  user      User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt    DateTime       @default(now())
  expiresAt    DateTime
  revoked      Boolean        @default(false)
  rotatedAt    DateTime?
  replacedById Int?
  replacedBy   RefreshToken?  @relation("ReplacedBy", fields: [replacedById], references: [id])
  previous     RefreshToken[] @relation("ReplacedBy")

  userAgent String?
  ipAddress String?
}

enum Category {
  venting
  confessions
  lonely
  grateful
  anxious
  happy
  love
  friendship
  work_school
  random
  motivational
  funny
  sad
  angry
  health
}
